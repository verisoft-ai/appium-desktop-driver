<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net481</TargetFramework>
    <Nullable>enable</Nullable>
    <LangVersion>10.0</LangVersion>
    <AllowUnsafeBlocks>false</AllowUnsafeBlocks>
    <AssemblyName>IEBridge</AssemblyName>
    <RootNamespace>IEBridge</RootNamespace>
  </PropertyGroup>
  <ItemGroup>
    <!-- EmbedInteropTypes: mshtml COM types embedded into the exe — no Microsoft.mshtml.dll needed at runtime -->
    <Reference Include="Microsoft.mshtml">
      <HintPath>$(MSBuildProgramFiles32)\Microsoft.NET\Primary Interop Assemblies\Microsoft.mshtml.dll</HintPath>
      <EmbedInteropTypes>true</EmbedInteropTypes>
    </Reference>
    <!-- Required for dynamic dispatch generated by COM interop with EmbedInteropTypes -->
    <Reference Include="Microsoft.CSharp" />
  </ItemGroup>
</Project>
