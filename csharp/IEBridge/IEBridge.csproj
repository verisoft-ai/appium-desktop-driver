<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net481</TargetFramework>
    <Nullable>enable</Nullable>
    <LangVersion>10.0</LangVersion>
    <AllowUnsafeBlocks>false</AllowUnsafeBlocks>
    <AssemblyName>IEBridge</AssemblyName>
    <RootNamespace>IEBridge</RootNamespace>
  </PropertyGroup>
  <ItemGroup>
    <!-- NuGet PIA — COM types embedded into the exe, no DLL needed at runtime -->
    <PackageReference Include="Microsoft.mshtml" Version="7.0.3300" >
      <EmbedInteropTypes>true</EmbedInteropTypes>
    </PackageReference>
    <!-- Required for dynamic dispatch generated by COM interop with EmbedInteropTypes -->
    <Reference Include="Microsoft.CSharp" />
  </ItemGroup>
</Project>
