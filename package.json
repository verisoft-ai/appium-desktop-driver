{
  "name": "appium-desktop-driver",
  "version": "2.2.0-preview.3",
  "description": "Appium driver for Windows",
  "keywords": [
    "appium",
    "desktop",
    "uiautomation",
    "automated testing",
    "windows",
    "verisoft",
    "desktop automation"
  ],
  "main": "build/lib/driver.js",
  "files": [
    "build/lib/**/*",
    "iedriver/**/*",
    "iebridge/IEBridge.exe",
    "native/win-x64/NovaUIAutomationServer.exe",
    "native/win-x64/appium-desktop-agent.jar",
    "scripts/postinstall.js",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "bin": {
    "desktop-driver-mcp": "build/lib/mcp/index.js"
  },
  "scripts": {
    "build": "tsc -b",
    "build:native": "dotnet publish csharp/NovaUIAutomationServer/NovaUIAutomationServer.csproj -c Release -o native/win-x64/",
    "build:iebridge": "dotnet publish csharp/IEBridge/IEBridge.csproj -r win-x86 -c Release -o iebridge/x86 && node -e \"const fs=require('fs');fs.copyFileSync('iebridge/x86/IEBridge.exe','iebridge/IEBridge.exe');\"",
    "build:java-agent": "cd java-agent && build.bat",
    "build:winform-test-app": "dotnet publish test-apps/winform-combo/WinformCombo.csproj -c Release -o test-apps/winform-combo/bin",
    "build:java-swing-test-app": "javac -d test-apps/java-swing-form test-apps/java-swing-form/TestForm.java",
    "build:test-apps": "npm run build:winform-test-app && npm run build:java-swing-test-app",
    "build:all": "npm run build:java-agent && npm run build:native && npm run build:iebridge && npm run build",
    "watch": "tsc -b --watch",
    "lint": "eslint .",
    "test": "npx vitest run",
    "test:e2e": "npx vitest run --config vitest.e2e.config.ts",
    "postinstall": "node scripts/postinstall.js",
    "mcp:start": "node build/lib/mcp/index.js",
    "pack:dist": "node scripts/pack-dist.js"
  },
  "author": "Automate The Planet",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/verisoft-ai/appium-desktop-driver.git"
  },
  "bugs": {
    "url": "https://github.com/verisoft-ai/appium-desktop-driver/issues"
  },
  "peerDependencies": {
    "appium": "^3.0.0-rc.2"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@appium/base-driver": "^10.1.0",
    "@aws-sdk/client-bedrock-runtime": "^3.1035.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@napi-rs/canvas": "^1.0.2",
    "@techstark/opencv-js": "^5.0.0-release.1",
    "appium-chromedriver": "^8.3.1",
    "bezier-easing": "^2.1.0",
    "koffi": "^2.14.1",
    "pngjs": "^7.0.0",
    "webdriverio": "^9.0.0",
    "xpath-analyzer": "^3.0.1",
    "zod": "^4.3.6"
  },
  "appium": {
    "driverName": "desktopdriver",
    "automationName": "DesktopDriver",
    "platformNames": [
      "Windows"
    ],
    "mainClass": "AppiumDesktopDriver"
  },
  "devDependencies": {
    "@appium/eslint-config-appium-ts": "^2.0.3",
    "@appium/tsconfig": "^1.1.0",
    "@appium/types": "^1.1.0",
    "@eslint/js": "^9.38.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/node": "^24.8.1",
    "@types/pngjs": "^6.0.5",
    "conventional-changelog-conventionalcommits": "^9.1.0",
    "eslint": "^9.38.0",
    "semantic-release": "^25.0.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.1",
    "vitest": "^2.1.0"
  }
}
